// Phase 2 persistence schema (Postgres). NOT wired into the app yet — the MVP
// is localStorage-first (see docs/database-plan.md). This is the record of the
// target shape so a server adapter can drop in behind lib/storage.ts without
// changing domain types. Arrays use Postgres String[]; enums kept as strings to
// mirror lib/types.ts exactly (no enum drift).
//
// To activate later: `npm i -D prisma @prisma/client`, set DATABASE_URL, then
// `npx prisma migrate dev`. Until then this file is inert documentation.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String       @id @default(cuid())
  email     String?      @unique
  name      String?
  timezone  String       @default("America/Montreal")
  createdAt DateTime     @default(now())

  seeds     Seed[]
  traces    DailyTrace[]
}

model Seed {
  id                   String   @id @default(cuid())
  userId               String?
  rawText              String
  title                String
  description          String?
  categories           String[]
  minimumAction        String
  estimatedDurationMin Int
  energyRequired       String
  locationType         String
  preferredTimes       String[]
  triggerConditions    String[]
  status               String   @default("active")

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User?    @relation(fields: [userId], references: [id])

  @@index([userId, status])
}

model Opportunity {
  id               String    @id @default(cuid())
  userId           String?
  seedId           String

  score            Float
  reason           String
  suggestedAction  String
  notificationText String
  contextJson      Json

  createdAt        DateTime  @default(now())
  acceptedAt       DateTime?
  dismissedAt      DateTime?
  completedAt      DateTime?
}

model DailyTrace {
  id            String   @id @default(cuid())
  userId        String?
  seedId        String?
  opportunityId String?
  date          String
  text          String
  category      String?
  partial       Boolean  @default(false)

  createdAt     DateTime @default(now())

  user          User?    @relation(fields: [userId], references: [id])

  @@index([userId, date])
}
